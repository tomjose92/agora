# Codex CLI bridge configuration.
#
# Copy this file to `.env` (in this same directory) and fill it in, then just
# run `python3 bridge.py` — no need to pass flags on the command line. Values
# here are loaded into the environment before startup; a real environment
# variable or a CLI flag of the same name always wins over the file.
#
#   cp .env.example .env
#   # edit .env, then:
#   python3 bridge.py
#
# `.env` is gitignored (this `.env.example` is the committed template). Point
# the bridge at a different file with `--env-file <path>` or AGORA_BRIDGE_ENV_FILE.

# --- Connection (required) --------------------------------------------------

# Agora hub base URL (http(s)/ws(s) accepted; /agent/ws is appended if missing).
# For a local hub the default ws://127.0.0.1:4470 works as-is.
AGORA_URL=https://your-agora-host

# Pairing token minted in Agora (Connections page, or POST /api/pairing).
# Prefer this over --token on the command line (that is visible in ps/proc).
AGORA_PAIRING_TOKEN=your-pairing-token

# Alternatively, read the token from a chmod 600 file instead of inlining it:
# AGORA_PAIRING_TOKEN_FILE=/home/you/.config/agora/codex-token

# --- Agent identity ---------------------------------------------------------

# AGENT_ID=codex-cli
# AGENT_NAME=Codex

# --- Codex CLI invocation ---------------------------------------------------

# Path/name of the codex binary (default: found on PATH).
# CODEX_BIN=codex

# Default model for every run (channels override with /model):
# any Codex model id, e.g. gpt-5.1-codex (empty = your codex config default)
# CODEX_MODEL=

# Default sandbox mode for every run, overridable per channel with /sandbox:
# read-only | workspace-write | danger-full-access | bypass
# (default: workspace-write; "bypass" disables the sandbox entirely — see
# SECURITY.md before using it)
# CODEX_SANDBOX=workspace-write

# Extra args added to every codex run (e.g. -c config overrides, --profile).
# A sandbox flag here also becomes the default, same as CODEX_SANDBOX.
# CODEX_ARGS=

# --- /new and worktrees -----------------------------------------------------

# Colon-separated directories that /new sessions may start under.
# /new is disabled when empty.
# CODEX_ALLOWED_ROOTS=/home/you/code:/home/you/work

# 1/true/yes: /new into a git repo creates an isolated worktree + branch per
# thread instead of binding the repo directly (also on demand via /worktree).
# CODEX_AUTO_WORKTREE=0

# --- Sandbox ----------------------------------------------------------------

# 1/true/yes: let /sandbox raise privilege above the bridge default.
# Off by default; lowering privilege is always allowed.
# CODEX_ALLOW_SANDBOX_ESCALATION=0

# --- TL;DR summaries --------------------------------------------------------

# 1/true/yes: ask Codex to add a toggleable short summary to long replies
# (off by default; channels override with /tldr).
# CODEX_TLDR=0

# Only replies at least this many chars long get a TL;DR.
# CODEX_TLDR_MIN_CHARS=1500

# --- Misc -------------------------------------------------------------------

# Per-run timeout in seconds.
# CODEX_TIMEOUT=1800

# How many sessions /sessions lists.
# SESSIONS_LIMIT=10

# Where per-channel session bindings are stored (default: state.json here).
# STATE_FILE=/home/you/.config/agora/codex-bridge-state.json

# In a multi-agent channel Codex replies only when @mentioned or when nobody
# was tagged, staying silent otherwise. Messages it stays silent on are buffered
# and replayed as context the next time it's addressed. Max buffered per channel
# (0 disables the buffer and the server-side context feed).
# CONTEXT_BUFFER=50

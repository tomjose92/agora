{
  "name": "agora-mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~57.0.4",
    "expo-audio": "~57.0.0",
    "expo-background-task": "~57.0.2",
    "expo-constants": "~57.0.3",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-manipulator": "~57.0.2",
    "expo-image-picker": "~57.0.2",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-sharing": "~57.0.3",
    "expo-status-bar": "~57.0.0",
    "expo-task-manager": "~57.0.2",
    "expo-web-browser": "~57.0.0",
    "lucide-react-native": "^1.24.0",
    "react": "19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@react-native/jest-preset": "^0.86.0",
    "@types/jest": "~29.5.14",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "jest": "~29.7.0",
    "jest-expo": "^57.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:integration": "AGORA_INTEGRATION=1 jest -c jest.integration.config.js --forceExit",
    "typecheck": "tsc --noEmit"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "tests/integration.test.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@shopify/flash-list)"
    ]
  }
}

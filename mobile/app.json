{
  "expo": {
    "name": "Agora",
    "slug": "agora",
    "version": "0.1.0",
    "scheme": "agora",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#101216",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.agora.mobile",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "10.0.0.0/8": { "NSExceptionAllowsInsecureHTTPLoads": true },
            "172.16.0.0/12": { "NSExceptionAllowsInsecureHTTPLoads": true },
            "192.168.0.0/16": { "NSExceptionAllowsInsecureHTTPLoads": true }
          }
        }
      }
    },
    "android": {
      "package": "app.agora.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#101216",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sharing",
      "expo-image",
      "./plugins/withNoPushEntitlement",
      "expo-background-task",
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": "Agora uses the microphone for voice messages and live voice conversations with agents."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Agora needs photo library access so you can attach images to messages.",
          "cameraPermission": "Agora uses the camera to take photos to attach to messages."
        }
      ]
    ]
  }
}

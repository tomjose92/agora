{
  "expo": {
    "name": "Agora",
    "slug": "agora",
    "version": "0.1.7",
    "scheme": "agora",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#101216",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.agora.mobile",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "10.0.0.0/8": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "172.16.0.0/12": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "192.168.0.0/16": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.agora.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#101216",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sharing",
      "expo-image",
      [
        "expo-notifications",
        {
          "color": "#101216"
        }
      ],
      "expo-background-task",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-audio",
        {
          "microphonePermission": "Agora uses the microphone for voice messages and live voice conversations with agents."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Agora needs photo library access so you can attach images to messages.",
          "cameraPermission": "Agora uses the camera to take photos to attach to messages."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "81d2da32-6efd-465a-b127-51c011bb0297"
      }
    }
  }
}

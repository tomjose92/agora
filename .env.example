# Agora server environment — copy to .env (or set on your PaaS, e.g. Railway).
#
# Everything here is optional: the server boots with none of it set. Values
# marked "persisted" are folded into <data-dir>/config.json at boot, so they
# also survive if you later unset the variable. Non-secret settings can be
# written straight into config.json instead; keep secrets out of it and pass
# them as env vars.

# ------------------------------------------------------------------ network

# Interface to bind. Loopback by default; 0.0.0.0 to accept LAN/remote
# clients (the Docker image already defaults to 0.0.0.0). Persisted.
#AGORA_BIND=0.0.0.0

# Listen port. AGORA_PORT wins over PORT (which PaaS platforms like Railway
# inject themselves). Persisted. Default: 4470.
#AGORA_PORT=4470

# --------------------------------------------------------- google sign-in
# Optional "Sign in with Google" for the web UI, desktop app, and mobile app,
# as an alternative to pasting the admin key. Create an OAuth client of
# type "Web application" at https://console.cloud.google.com/apis/credentials
# and register the redirect URI:  <AGORA_PUBLIC_URL>/api/auth/google/callback
# All four are persisted into config.json.

# The OAuth client credentials.
#AGORA_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
#AGORA_GOOGLE_CLIENT_SECRET=GOCSPX-...

# The ONLY Google accounts allowed to sign in (comma-separated). This is the
# authorization layer: Agora v1 is single-user, so every allowed email signs
# in as the owner. Leaving it empty keeps Google sign-in disabled.
#AGORA_GOOGLE_ALLOWED_EMAILS=you@gmail.com,partner@gmail.com

# Public https origin of this deployment — must match the host in the
# redirect URI registered with Google. Without it the callback URL is derived
# per request from Host/X-Forwarded-Proto headers.
#AGORA_PUBLIC_URL=https://agora.up.railway.app

# ------------------------------------------------------------------- voice

# Enables server-side voice (speech-to-text for voice messages and spoken
# playback of agent replies) via OpenAI's audio APIs. Voice UI stays hidden
# on all clients when unset. Read from the environment on every use — not
# persisted to config.json.
#OPENAI_API_KEY=sk-...

# --------------------------------------------------------------- migration

# Seed a BRAND-NEW data dir (no agora.db yet) by downloading an export
# archive on first boot; ignored once data exists. Handy for standing up a
# fresh deployment from a backup.
#AGORA_IMPORT_URL=https://example.com/agora-export.tar.gz

# ----------------------------------------------------------------- logging

# Standard tracing filter (error|warn|info|debug|trace, per-module syntax).
#RUST_LOG=info

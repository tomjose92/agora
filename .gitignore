# Rust build artifacts
/target/

# Tauri codegen (regenerated on every build)
crates/agora-desktop/gen/schemas/

# Runtime state (headless server default data dir)
/data/

# Node (Tauri CLI is invoked via npx; nothing should land here)
node_modules/

# Expo mobile app: native project is generated by `expo prebuild`/`expo run`
mobile/ios/
mobile/android/
mobile/.expo/

# Local environment (secrets); .env.example is the committed template
.env

# Bridge runtime state (per-machine channel->session bindings)
bridges/claude-cli/state.json

# Python bytecode (the bridges are Python)
__pycache__/
*.pyc

# OS noise
.DS_Store
